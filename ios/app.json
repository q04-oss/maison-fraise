{
  "expo": {
    "name": "fraise",
    "slug": "maison-fraise",
    "scheme": "boxfraise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F5F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.boxfraise.app",
      "entitlements": {
        "com.apple.developer.in-app-payments": [
          "merchant.com.boxfraise.app"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationUsageDescription": "We'll notify you when event dates are confirmed."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ec4ad15d-2535-42a4-91a0-70599925e6f5"
    },
    "plugins": [
      "expo-updates",
      "expo-font",
      "expo-notifications",
      "expo-secure-store",
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "ec4ad15d-2535-42a4-91a0-70599925e6f5"
      }
    }
  }
}
